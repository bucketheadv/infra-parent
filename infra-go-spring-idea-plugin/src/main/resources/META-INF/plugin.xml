<idea-plugin>
    <id>io.infra.idea.plugin.go-spring</id>
    <name>Infra Go-Spring Support</name>
    <vendor email="support@infra.io">infra</vendor>

    <description><![CDATA[
        Support go-spring autowire and value navigation for Go projects.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.properties</depends>
    <depends>org.jetbrains.plugins.yaml</depends>
    <depends>org.jetbrains.plugins.go</depends>

    <extensions defaultExtensionNs="com.intellij">
        <psi.referenceContributor implementation="io.infra.idea.plugin.gospring.reference.GoSpringReferenceContributor"/>
        <gotoDeclarationHandler implementation="io.infra.idea.plugin.gospring.navigation.GoSpringGotoDeclarationHandler"/>
        <codeInsight.lineMarkerProvider language="go" implementationClass="io.infra.idea.plugin.gospring.navigation.GoSpringLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider implementationClass="io.infra.idea.plugin.gospring.navigation.GoSpringPropertyLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider implementationClass="io.infra.idea.plugin.gospring.navigation.GoSpringYamlLineMarkerProvider"/>
        <annotator language="go" implementationClass="io.infra.idea.plugin.gospring.inspection.GoSpringGormTagAnnotator"/>
        <annotator language="go" implementationClass="io.infra.idea.plugin.gospring.inspection.GoSpringGormSqlAnnotator"/>
        <localInspection language="go" implementationClass="io.infra.idea.plugin.gospring.inspection.GoSpringGormTagInspection"/>
        <completion.contributor language="go" implementationClass="io.infra.idea.plugin.gospring.completion.GoSpringGormTagCompletionContributor"/>
        <completion.contributor language="any" implementationClass="io.infra.idea.plugin.gospring.metadata.GoSpringConfigMetadataCompletionContributor"/>
        <typedHandler implementation="io.infra.idea.plugin.gospring.metadata.GoSpringConfigMetadataTypedHandler"/>
        <documentationProvider implementation="io.infra.idea.plugin.gospring.metadata.GoSpringConfigMetadataDocumentationProvider"/>
        <lang.documentationProvider language="Properties" implementationClass="io.infra.idea.plugin.gospring.metadata.GoSpringConfigMetadataDocumentationProvider"/>
        <lang.documentationProvider language="YAML" implementationClass="io.infra.idea.plugin.gospring.metadata.GoSpringConfigMetadataDocumentationProvider"/>
    </extensions>
</idea-plugin>
